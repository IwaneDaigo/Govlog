{
  "name": "gov-sync",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "concurrently \"pnpm dev:api\" \"pnpm dev:web\"",
    "dev:all": "concurrently -k -n PY,API,WEB -c green,blue,magenta \"pnpm dev:python\" \"pnpm dev:api:similarity\" \"pnpm dev:web\"",
    "dev:python": "node scripts/run.js dev-python",
    "dev:api:similarity": "node scripts/run.js dev-api-similarity",
    "dev:web": "pnpm --filter @gov-sync/web dev",
    "dev:api": "pnpm --filter @gov-sync/api dev",
    "build": "pnpm --filter @gov-sync/api build && pnpm --filter @gov-sync/web build"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
