{
  "name": "gov-sync",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "concurrently \"pnpm dev:api\" \"pnpm dev:web\"",
    "dev:all": "concurrently \"pnpm dev:python\" \"pnpm dev:api:similarity\" \"pnpm dev:web\"",
    "dev:python": "cd python-similarity && ..\\.venv\\Scripts\\python.exe -m uvicorn app.main:app --host 127.0.0.1 --port 8000 --reload",
    "dev:api:similarity": "set SIMILARITY_API_BASE_URL=http://127.0.0.1:8000&& pnpm --filter @gov-sync/api dev",
    "dev:web": "pnpm --filter @gov-sync/web dev",
    "dev:api": "pnpm --filter @gov-sync/api dev",
    "build": "pnpm --filter @gov-sync/api build && pnpm --filter @gov-sync/web build"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
